<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenWeatherApp.Views.SettingsPage"
             Title="SettingsPage">
    <StackLayout>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Label
                Text="Use Imperial instead of Metric"
                Grid.Column="0"
                HorizontalOptions="Start" />
            <Switch x:Name="TemperatureTypeSwitch"
                    Grid.Column="1"
                    HorizontalOptions="End"
                    Toggled="TemperatureTypeSwitch_Toggled" />
        </Grid>
    </StackLayout>
</ContentPage>
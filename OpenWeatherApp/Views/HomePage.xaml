<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenWeatherApp.Views.HomePage"
             Title="HomePage">
    <StackLayout
        Margin="20, 0"
        Padding="5">
        <Button
            Padding="10"
            x:Name="LoadLocalWeather"
            Text="Load Local Weather"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Clicked="LoadLocalWeather_Clicked" />
        <ScrollView>
            <CollectionView x:Name="HomeCollectionView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid BackgroundColor="LightCoral"
                              Padding="10, 10"
                              >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="5" />
                                <RowDefinition Height="8*" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="0.5*" />
                                <RowDefinition Height="2*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding cityName}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Text="{Binding temp}"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   HorizontalOptions="End"
                                   VerticalOptions="Start" />
                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Text="°C"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Start"
                                   VerticalOptions="Start" />
                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Text="Feels like: "
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="End"
                                   VerticalOptions="End" />
                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding feels_like}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Start"
                                   VerticalOptions="End" />
                            <Image Grid.Row="2"
                                   Grid.RowSpan="3"
                                   Grid.Column="2"
                                   Grid.ColumnSpan="2"
                                   Source="{Binding weather[0].icon}"/>
                            <Label Grid.Row="4"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding max_temp}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="End" />
                            <Label Grid.Row="4"
                                   Grid.Column="1"
                                   Text="{Binding min_temp}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="End" />
                            <Label Grid.Row="5"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="max"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Start" />
                            <Label Grid.Row="5"
                                   Grid.Column="1"
                                   Text="min"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Start" />
                            <Label Padding="0, 10"
                                   Grid.Row="6"
                                   Grid.Column="0"
                                   Text="Description: "
                                   FontAttributes="Bold"
                                   HorizontalOptions="End"
                                   VerticalOptions="End" />
                            <Label Padding="0, 10"
                                   Grid.Row="6"
                                   Grid.Column="1"
                                   Text="{Binding weather[0].description}"
                                   HorizontalOptions="Start"
                                   VerticalOptions="End" />

                            <Label Padding="0, 10"
                                   Grid.Row="6"
                                   Grid.Column="4"
                                   Text="{Binding dateTime}"
                                   HorizontalTextAlignment="Center"
                                   HorizontalOptions="Start"
                                   VerticalOptions="End" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>
    </StackLayout>
</ContentPage>
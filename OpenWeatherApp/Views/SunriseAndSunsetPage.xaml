<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenWeatherApp.Views.SunriseAndSunsetPage"
             Title="SunriseAndSunsetPage">
    <StackLayout>
        <SearchBar
            x:Name="SunriseAndSunsetSearchBar"
            Placeholder="Search city name..."
            SearchButtonPressed="SunriseAndSunsetSearchBar_SearchButtonPressed"/>
        <CollectionView x:Name="RiseAndSetCollectionView" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid HorizontalOptions="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label
                            Padding="0,10,0,0"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Grid.Row="0"
                            Text="{Binding cityName}"
                            TextColor="Black"
                            FontSize="24"
                            HorizontalOptions="Center"/>
                        <Label
                            Padding="0,10,0,0"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Grid.Row="1"
                            Text="{Binding dateTime}"
                            TextColor="Black"
                            FontSize="24"
                            HorizontalOptions="Center"/>
                        <Label
                            Padding="0,10,0,0"
                            Grid.Column="0"
                            Grid.Row="2"
                            Text="{Binding new_sunrise}"
                            TextColor="Black"
                            FontSize="24"
                            HorizontalOptions="Center"/>
                        <Label
                            Padding="0,10,0,0"
                            Grid.Column="1"
                            Grid.Row="2"
                            Text="{Binding new_sunset}"
                            TextColor="Black"
                            FontSize="24"
                            HorizontalOptions="Center"/>
                        <Label
                            Padding="0,10,0,0"
                            Grid.Column="0"
                            Grid.Row="3"
                            Text="Sunrise"
                            TextColor="Black"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"/>
                        <Label
                            Padding="0,10,0,0"
                            Grid.Column="1"
                            Grid.Row="3"
                            Text="Sunset"
                            TextColor="Black"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>